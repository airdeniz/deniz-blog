---
import BaseLayout from './BaseLayout.astro';
import { formatDate, joinBase } from '../utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  readTime: string;
}

const { post, readTime } = Astro.props;
const { title, description, pubDate, updatedDate, tags } = post.data;
---
<BaseLayout title={title} description={description}>
  <article class="container post">
    <a href={joinBase('blog/')} class="back">← Tüm yazılar</a>

    <header class="post-header">
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        <span class="dot">·</span>
        <span>{readTime}</span>
      </div>
      <h1>{title}</h1>
      <p class="lede">{description}</p>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>

    {updatedDate && (
      <p class="updated muted">Son güncelleme: {formatDate(updatedDate)}</p>
    )}
  </article>
</BaseLayout>

<style>
  .post { padding-top: 2.5rem; }
  .back {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--text-soft);
    margin-bottom: 2rem;
  }
  .post-header { margin-bottom: 2.5rem; }
  .post-meta {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .dot { opacity: 0.5; }
  .lede {
    font-size: 1.2rem;
    color: var(--text-soft);
    margin: 0.6rem 0 1rem;
    line-height: 1.55;
  }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .updated {
    margin-top: 3rem;
    font-size: 0.88rem;
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }
  /* Yazı gövdesi için üst boşluk ayarı */
  .prose :global(h2) { scroll-margin-top: 80px; }
  .prose :global(h3) { scroll-margin-top: 80px; }
</style>
