---
import BaseLayout from './BaseLayout.astro';
import { formatDate, joinBase } from '../utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  readTime: string;
}

const { post, readTime } = Astro.props;
const { title, description, pubDate, updatedDate, tags } = post.data;
const sourceUrl = new URL(Astro.url.pathname, Astro.site).href;
---
<BaseLayout title={title} description={description}>
  <article class="container post">
    <div class="post-toolbar no-print">
      <a href={joinBase('blog/')} class="back">← Tüm yazılar</a>
      <button type="button" class="pdf-btn" id="pdf-btn" aria-label="Bu yazıyı PDF olarak indir">
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
          <polyline points="7 10 12 15 17 10" />
          <line x1="12" y1="15" x2="12" y2="3" />
        </svg>
        <span>PDF indir</span>
      </button>
    </div>

    <header class="post-header">
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        <span class="dot">·</span>
        <span>{readTime}</span>
      </div>
      <h1>{title}</h1>
      <p class="lede">{description}</p>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>

    {updatedDate && (
      <p class="updated muted">Son güncelleme: {formatDate(updatedDate)}</p>
    )}

    <p class="print-only print-source">Kaynak: {sourceUrl}</p>
  </article>
</BaseLayout>

<script>
  // Açık tema paleti — koyu tema seçili olsa bile PDF beyaz zeminde üretilsin
  const LIGHT_VARS: Record<string, string> = {
    '--bg': '#ffffff',
    '--bg-soft': '#f2f1ec',
    '--surface': '#ffffff',
    '--border': '#e6e3db',
    '--text': '#1c1b19',
    '--text-soft': '#55524c',
    '--text-muted': '#8a867e',
    '--accent': '#c2410c',
    '--accent-soft': '#fdece3',
    '--code-bg': '#f4f2ee',
  };

  const btn = document.getElementById('pdf-btn') as HTMLButtonElement | null;
  const label = btn?.querySelector('span');

  btn?.addEventListener('click', async () => {
    const article = document.querySelector('article.post');
    if (!article || btn.disabled) return;

    const original = label?.textContent ?? 'PDF indir';
    btn.disabled = true;
    if (label) label.textContent = 'Hazırlanıyor…';

    // Ekrandaki kabuğu (toolbar) çıkarıp içeriği klonla, kaynak satırını göster
    const clone = article.cloneNode(true) as HTMLElement;
    clone.querySelectorAll('.no-print').forEach((el) => el.remove());
    clone
      .querySelectorAll<HTMLElement>('.print-only')
      .forEach((el) => (el.style.display = 'block'));

    // Ekran dışında, açık temaya zorlanmış bir kapsayıcıya yerleştir
    const holder = document.createElement('div');
    Object.entries(LIGHT_VARS).forEach(([k, v]) => holder.style.setProperty(k, v));
    holder.style.position = 'fixed';
    holder.style.left = '-10000px';
    holder.style.top = '0';
    holder.style.width = '800px';
    holder.style.background = '#ffffff';
    holder.style.color = '#1c1b19';
    holder.style.padding = '28px 32px';
    holder.appendChild(clone);
    document.body.appendChild(holder);

    const rawTitle = document.querySelector('h1')?.textContent?.trim() || 'yazi';
    const filename =
      rawTitle.replace(/[\\/:*?"<>|]+/g, '').replace(/\s+/g, '-') + '.pdf';

    try {
      const { default: html2pdf } = await import('html2pdf.js');
      await html2pdf()
        .set({
          margin: [10, 10, 12, 10],
          filename,
          image: { type: 'jpeg', quality: 0.98 },
          html2canvas: { scale: 2, useCORS: true, backgroundColor: '#ffffff' },
          jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' },
          pagebreak: { mode: ['avoid-all', 'css', 'legacy'] },
        })
        .from(holder)
        .save();
    } catch (err) {
      console.error('PDF oluşturulamadı:', err);
      alert('PDF oluşturulurken bir sorun oluştu. Lütfen tekrar deneyin.');
    } finally {
      holder.remove();
      btn.disabled = false;
      if (label) label.textContent = original;
    }
  });
</script>

<style>
  .post { padding-top: 2.5rem; }
  .post-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .back {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--text-soft);
  }
  .pdf-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: inherit;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-soft);
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.35em 0.85em;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .pdf-btn:hover { color: var(--accent); border-color: var(--accent); }
  .pdf-btn:disabled { opacity: 0.6; cursor: default; }
  .pdf-btn:disabled:hover { color: var(--text-soft); border-color: var(--border); }
  .pdf-btn svg { flex-shrink: 0; }
  .print-only { display: none; }
  .post-header { margin-bottom: 2.5rem; }
  .post-meta {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .dot { opacity: 0.5; }
  .lede {
    font-size: 1.2rem;
    color: var(--text-soft);
    margin: 0.6rem 0 1rem;
    line-height: 1.55;
  }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .updated {
    margin-top: 3rem;
    font-size: 0.88rem;
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }
  /* Yazı gövdesi için üst boşluk ayarı */
  .prose :global(h2) { scroll-margin-top: 80px; }
  .prose :global(h3) { scroll-margin-top: 80px; }
</style>
