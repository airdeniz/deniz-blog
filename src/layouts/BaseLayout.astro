---
import { SITE } from '../config';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import {
  SITE_DESCRIPTION,
  getLocaleFromPath,
  getAlternatePath,
  type Locale,
} from '../i18n';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /** Sosyal paylaşım için sayfaya özel görsel (opsiyonel) */
  image?: string;
  /** Sayfa dili — verilmezse URL'den çıkarılır */
  lang?: Locale;
}

const lang: Locale = Astro.props.lang ?? getLocaleFromPath(Astro.url.pathname);

const {
  title,
  description = SITE_DESCRIPTION[lang],
  image,
} = Astro.props;

const altPath = getAlternatePath(Astro.url.pathname);
const pageTitle = title ? `${title} — ${SITE.author}` : SITE.title;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = image ? new URL(image, Astro.site).href : undefined;

// Çift slash'ı temizleyerek base ile birleştir (regex'i şablon dışında tutuyoruz)
const base = import.meta.env.BASE_URL;
const withBase = (p: string) => (base + '/' + p).replace(/\/{2,}/g, '/');
const faviconHref = withBase('favicon.svg');
const rssHref = withBase(lang === 'en' ? 'en/rss.xml' : 'rss.xml');
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href={rssHref} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />

    <!-- Fontlar -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;650&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&display=swap"
      rel="stylesheet"
    />

    <!-- Tema: FOUC olmaması için render'dan önce uygula -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = stored || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <Header lang={lang} altPath={altPath} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
