---
const base = import.meta.env.BASE_URL;
const searchUrl = (base + '/search.json').replace(/\/{2,}/g, '/');
---
<button id="search-open" class="search-btn" aria-label="Ara" title="Ara ( / )">
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path></svg>
</button>

<div id="search-modal" class="search-modal" hidden>
  <div class="search-panel" role="dialog" aria-modal="true" aria-label="Site içi arama">
    <div class="search-input-row">
      <svg class="search-input-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path></svg>
      <input id="search-input" type="search" placeholder="Yazılarda ara…" autocomplete="off" spellcheck="false" />
      <kbd class="search-esc">esc</kbd>
    </div>
    <ul id="search-results" class="search-results"></ul>
    <p id="search-empty" class="search-empty" hidden>Sonuç bulunamadı.</p>
    <div id="search-hint" class="search-footer">
      <span><kbd>↑</kbd><kbd>↓</kbd> gezin</span>
      <span><kbd>↵</kbd> aç</span>
      <span><kbd>esc</kbd> kapat</span>
    </div>
  </div>
</div>

<style>
  .search-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-soft);
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .search-btn:hover { color: var(--accent); border-color: var(--accent); }

  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 12vh 16px 16px;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(2px);
  }
  .search-modal[hidden] { display: none; }
  .search-panel {
    position: relative;
    width: 100%;
    max-width: 580px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    box-shadow: var(--shadow);
    overflow: hidden;
    animation: search-in 0.14s ease;
  }
  @keyframes search-in {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .search-input-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.95rem 1.1rem;
    border-bottom: 1px solid var(--border);
  }
  .search-input-icon { color: var(--text-muted); flex-shrink: 0; }
  #search-input {
    flex: 1;
    border: none;
    background: none;
    outline: none;
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 1.05rem;
  }
  #search-input::placeholder { color: var(--text-muted); }
  .search-esc {
    font-size: 0.7rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 0.1em 0.4em;
    flex-shrink: 0;
  }

  .search-results { list-style: none; margin: 0; padding: 0.5rem; max-height: 58vh; overflow-y: auto; }
  .search-results li { margin: 0; }
  .search-result {
    position: relative;
    display: block;
    padding: 0.7rem 0.85rem;
    border-radius: 10px;
    color: inherit;
    border: 1px solid transparent;
    transition: background 0.12s ease, border-color 0.12s ease;
  }
  .search-result:hover,
  .search-result.is-active {
    background: var(--bg-soft);
    border-color: var(--border);
    text-decoration: none;
    outline: none;
  }
  .sr-head { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; }
  .sr-title { font-weight: 600; color: var(--text); font-size: 1rem; line-height: 1.35; }
  .search-result:hover .sr-title,
  .search-result.is-active .sr-title { color: var(--accent); }
  .sr-arrow {
    color: var(--accent);
    flex-shrink: 0;
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.15s ease;
    font-size: 1rem;
  }
  .search-result:hover .sr-arrow,
  .search-result.is-active .sr-arrow { opacity: 1; transform: translateX(0); }
  .sr-desc {
    color: var(--text-soft);
    font-size: 0.85rem;
    line-height: 1.45;
    margin-top: 0.2rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .sr-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.5rem; }
  .sr-tag {
    font-size: 0.72rem;
    color: var(--text-muted);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.1em 0.6em;
  }
  .search-result mark { background: var(--accent-soft); color: var(--accent); border-radius: 3px; padding: 0 2px; }

  .search-empty {
    margin: 0;
    padding: 1.6rem 1rem;
    font-size: 0.9rem;
    color: var(--text-muted);
    text-align: center;
  }
  .search-footer {
    display: flex;
    gap: 1.1rem;
    padding: 0.6rem 1.1rem;
    border-top: 1px solid var(--border);
    font-size: 0.75rem;
    color: var(--text-muted);
  }
  .search-footer kbd {
    font-family: var(--font-mono);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0 0.35em;
    margin-right: 0.15em;
    background: var(--bg);
  }

  @media (max-width: 640px) {
    .search-modal { padding: 8vh 12px 12px; }
    .search-footer { display: none; }
  }
</style>

<script define:vars={{ searchUrl }}>
  (function () {
    const openBtn = document.getElementById('search-open');
    const modal = document.getElementById('search-modal');
    const input = document.getElementById('search-input');

    // Header'ın backdrop-filter'ı, position:fixed olan modalı header kutusuna
    // hapsediyor. Modalı doğrudan body'e taşıyarak tüm ekranı kaplamasını sağla.
    if (modal && modal.parentElement !== document.body) {
      document.body.appendChild(modal);
    }
    const resultsEl = document.getElementById('search-results');
    const emptyEl = document.getElementById('search-empty');
    const hintEl = document.getElementById('search-hint');
    let index = null;
    let loaded = false;
    let activeIndex = -1;

    async function loadIndex() {
      if (loaded) return;
      loaded = true;
      try {
        const res = await fetch(searchUrl);
        index = await res.json();
      } catch (e) {
        index = [];
      }
    }

    function openModal() {
      modal.hidden = false;
      loadIndex();
      setTimeout(() => input.focus(), 20);
    }
    function closeModal() {
      modal.hidden = true;
      input.value = '';
      resultsEl.innerHTML = '';
      emptyEl.hidden = true;
      hintEl.hidden = false;
      activeIndex = -1;
    }

    function escapeHtml(s) {
      return s.replace(/[&<>"']/g, (c) =>
        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c])
      );
    }
    function highlight(text, q) {
      const i = text.toLowerCase().indexOf(q);
      if (i === -1) return escapeHtml(text);
      return (
        escapeHtml(text.slice(0, i)) +
        '<mark>' + escapeHtml(text.slice(i, i + q.length)) + '</mark>' +
        escapeHtml(text.slice(i + q.length))
      );
    }

    // Alaka puanı: başlık/açıklama/etiket eşleşmeleri öncelikli.
    function scoreOf(p, q) {
      let s = 0;
      if (p.title.toLowerCase().includes(q)) s += 100;
      if (p.description.toLowerCase().includes(q)) s += 50;
      if ((p.tags || []).some((t) => t.toLowerCase().includes(q))) s += 40;
      return s;
    }

    function render(raw) {
      const query = raw.trim().toLowerCase();
      resultsEl.innerHTML = '';
      activeIndex = -1;
      if (!query || !index) { emptyEl.hidden = true; hintEl.hidden = false; return; }
      hintEl.hidden = false;

      const scored = index.map((p) => ({
        p,
        score: scoreOf(p, query),
        body: (p.content || '').includes(query),
      }));
      const primary = scored.filter((x) => x.score > 0).sort((a, b) => b.score - a.score);
      // Güçlü eşleşme varsa yalnızca onları göster; yoksa gövde eşleşmelerine düş.
      const list = (primary.length ? primary : scored.filter((x) => x.body)).slice(0, 8);

      if (list.length === 0) { emptyEl.hidden = false; return; }
      emptyEl.hidden = true;

      for (const { p } of list) {
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = p.url;
        a.className = 'search-result';
        const tags = (p.tags || [])
          .slice(0, 3)
          .map((t) => '<span class="sr-tag">' + escapeHtml(t) + '</span>')
          .join('');
        a.innerHTML =
          '<span class="sr-head">' +
          '<span class="sr-title">' + highlight(p.title, query) + '</span>' +
          '<span class="sr-arrow">→</span>' +
          '</span>' +
          '<span class="sr-desc">' + highlight(p.description, query) + '</span>' +
          (tags ? '<span class="sr-tags">' + tags + '</span>' : '');
        li.appendChild(a);
        resultsEl.appendChild(li);
      }
    }

    function items() {
      return Array.from(resultsEl.querySelectorAll('a.search-result'));
    }
    function setActive(next) {
      const list = items();
      if (!list.length) return;
      if (activeIndex >= 0 && list[activeIndex]) list[activeIndex].classList.remove('is-active');
      activeIndex = (next + list.length) % list.length;
      const el = list[activeIndex];
      el.classList.add('is-active');
      el.scrollIntoView({ block: 'nearest' });
    }

    openBtn && openBtn.addEventListener('click', openModal);
    // Panel dışındaki karartılmış boşluğa tıklayınca (Esc gibi) kapat
    modal && modal.addEventListener('mousedown', (e) => {
      if (e.target === modal) closeModal();
    });
    input && input.addEventListener('input', (e) => render(e.target.value));
    input && input.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') { e.preventDefault(); setActive(activeIndex + 1); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); setActive(activeIndex - 1); }
      else if (e.key === 'Enter') {
        const list = items();
        const target = activeIndex >= 0 ? list[activeIndex] : list[0];
        if (target) target.click();
      }
    });

    document.addEventListener('keydown', (e) => {
      const tag = (document.activeElement && document.activeElement.tagName) || '';
      const typing = /INPUT|TEXTAREA|SELECT/.test(tag);
      if (((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') || (e.key === '/' && !typing)) {
        e.preventDefault();
        openModal();
      } else if (e.key === 'Escape' && !modal.hidden) {
        closeModal();
      }
    });
  })();
</script>
