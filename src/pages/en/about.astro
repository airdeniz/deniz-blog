---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../config';
import { useTranslations } from '../../i18n';

const lang = 'en';
const t = useTranslations(lang);
const hasUser = (url: string) => !url.includes('KULLANICIADI');
const bodyHtml = t('aboutBody', { name: `<strong>${SITE.author}</strong>` });
---
<BaseLayout title={t('aboutTitle')} description={`${SITE.author} — ${t('aboutTitle')}`} lang={lang}>
  <section class="container about">
    <h1>{t('aboutTitle')}</h1>

    <p set:html={bodyHtml}></p>

    <h2>{t('aboutContact')}</h2>
    <ul class="contact">
      {SITE.email && (
        <li><span class="k">{t('contactEmail')}</span><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
      )}
      {SITE.github && hasUser(SITE.github) && (
        <li><span class="k">GitHub</span><a href={SITE.github} target="_blank" rel="noopener">{SITE.github.replace('https://', '')}</a></li>
      )}
      {SITE.linkedin && hasUser(SITE.linkedin) && (
        <li><span class="k">LinkedIn</span><a href={SITE.linkedin} target="_blank" rel="noopener">{SITE.linkedin.replace('https://www.', '').replace('https://', '')}</a></li>
      )}
    </ul>

  </section>
</BaseLayout>

<style>
  .about { padding-top: 3rem; max-width: 640px; }
  .contact { list-style: none; margin: 1rem 0 2rem; padding: 0; }
  .contact li {
    display: flex;
    gap: 1rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .contact .k {
    min-width: 90px;
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .note { margin-top: 2rem; font-size: 0.9rem; }
</style>
